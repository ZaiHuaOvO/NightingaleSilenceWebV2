{
  "name": "nightingalesilence-web",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:armoire-catalog": "node scripts/build-armoire-catalog.mjs",
    "typecheck": "vue-tsc -b",
    "build": "vue-tsc -b && vite build",
    "check:i18n": "node scripts/check-ui-copy.mjs",
    "check": "npm run typecheck && npm run check:i18n && vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\""
  },
  "dependencies": {
    "pinia": "^2.1.7",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "prettier": "^3.9.4",
    "typescript": "~5.7.3",
    "vite": "^6.2.4",
    "vue-tsc": "^2.2.8"
  }
}
